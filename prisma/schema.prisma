generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// ENUMS
// ========================

enum UserRole {
  SUPERADMIN
  DOCTOR
  STAFF
  CUSTOMER
}

enum ModuleName {
  ONLINE_BOOKING
  CUSTOMER_PORTAL
  APPOINTMENT
  MEDICAL_RECORD
  VACCINATION
  INPATIENT
  GROOMING
  INVENTORY
  POS_BILLING
  ACCOUNTING
  NOTIFICATION_WA
  NOTIFICATION_EMAIL
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum InvoiceStatus {
  UNPAID
  PAID
  PARTIAL
  CANCELLED
}

enum PaymentMethod {
  CASH
  TRANSFER
  KARTU
  QRIS
}

enum CageStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum InpatientStatus {
  ADMITTED
  OBSERVED
  DISCHARGED
}

enum GroomingStatus {
  BOOKED
  PROCESSING
  COMPLETED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  INVOICE_CREATED
  MODULE_ENABLED
  MODULE_DISABLED
  MEDICAL_RECORD_CREATED
  APPOINTMENT_CREATED
  APPOINTMENT_COMPLETED
}

enum QueueStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  RETRYING
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
  EXPIRED
  PRESCRIPTION
  POS
}

// ========================
// CORE
// ========================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  phone     String?
  avatar    String?
  isLocked  Boolean  @default(false)
  loginAttempts Int  @default(0)
  lastLoginAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  clinicUsers    ClinicUser[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  inpatients     Inpatient[]
  invoices       Invoice[]
  notifications  Notification[]
  notificationQueue NotificationQueue[]
  auditLogs      AuditLog[]
  userPermissions UserPermission[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Clinic {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  address   String?
  phone     String?
  email     String?
  logo      String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  // Relations
  users          ClinicUser[]
  modules        ClinicModule[]
  customers      Customer[]
  pets           Pet[]
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]
  cages          Cage[]
  inpatients     Inpatient[]
  groomings      Grooming[]
  products       Product[]
  suppliers      Supplier[]
  invoices       Invoice[]
  notifications  Notification[]
  notificationQueue NotificationQueue[]
  auditLogs      AuditLog[]
  transactions   AccountingTransaction[]
  ledgerAccounts LedgerAccount[]
  journalEntries JournalEntry[]

  @@index([slug])
  @@index([isActive])
  @@map("clinics")
}

model ClinicUser {
  id        String   @id @default(cuid())
  clinicId  String
  userId    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clinicId, userId])
  @@index([clinicId])
  @@index([userId])
  @@map("clinic_users")
}

model ClinicModule {
  id        String   @id @default(cuid())
  clinicId  String
  module    ModuleName
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, module])
  @@index([clinicId])
  @@index([module])
  @@map("clinic_modules")
}

// ========================
// PERMISSION MATRIX
// ========================

model Permission {
  id        String   @id @default(cuid())
  name      String   @unique
  key       String   @unique
  group     String?
  createdAt DateTime @default(now())

  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@index([key])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id           String   @id @default(cuid())
  userId       String
  permissionId String
  granted      Boolean  @default(true)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@map("user_permissions")
}

// ========================
// CUSTOMER & PET
// ========================

model Customer {
  id        String   @id @default(cuid())
  clinicId  String
  userId    String?
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  clinic  Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pets    Pet[]
  invoices Invoice[]

  @@index([clinicId])
  @@index([phone])
  @@index([email])
  @@map("customers")
}

model Pet {
  id         String   @id @default(cuid())
  clinicId   String
  customerId String
  name       String
  species    String
  breed      String?
  gender     String?
  birthDate  DateTime?
  weight     Float?
  color      String?
  photo      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customer       Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  appointments   Appointment[]
  medicalRecords MedicalRecord[]
  vaccinations   Vaccination[]
  inpatients     Inpatient[]
  groomings      Grooming[]

  @@index([clinicId])
  @@index([customerId])
  @@index([name])
  @@map("pets")
}

// ========================
// APPOINTMENT
// ========================

model Appointment {
  id          String            @id @default(cuid())
  clinicId    String
  petId       String
  doctorId    String
  customerId  String?
  date        DateTime
  time        String
  status      AppointmentStatus @default(SCHEDULED)
  queueNumber Int?
  notes       String?
  serviceType String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  clinic  Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet     Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)
  doctor  User   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([doctorId])
  @@index([petId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

// ========================
// MEDICAL RECORD (SOAP)
// ========================

model MedicalRecord {
  id          String   @id @default(cuid())
  clinicId    String
  petId       String
  doctorId    String
  appointmentId String?
  subjective  String?
  objective   String?
  assessment  String?
  plan        String?
  diagnosis   String?
  action      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  clinic      Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet         Pet         @relation(fields: [petId], references: [id], onDelete: Cascade)
  doctor      User        @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  attachments MedicalRecordAttachment[]
  prescriptions Prescription[]

  @@index([clinicId])
  @@index([petId])
  @@index([doctorId])
  @@map("medical_records")
}

model MedicalRecordAttachment {
  id              String @id @default(cuid())
  medicalRecordId String
  fileName        String
  fileUrl         String
  fileType        String
  createdAt       DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)

  @@map("medical_record_attachments")
}

// ========================
// VACCINATION
// ========================

model Vaccination {
  id              String   @id @default(cuid())
  clinicId        String
  petId           String
  vaccineName     String
  dateAdministered DateTime
  nextDueDate     DateTime?
  batchNumber     String?
  notes           String?
  certificateUrl  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([petId])
  @@index([nextDueDate])
  @@map("vaccinations")
}

// ========================
// INPATIENT
// ========================

model Cage {
  id        String     @id @default(cuid())
  clinicId  String
  name      String
  type      String?
  status    CageStatus @default(AVAILABLE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  clinic     Clinic      @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  inpatients Inpatient[]

  @@unique([clinicId, name])
  @@index([clinicId])
  @@index([status])
  @@map("cages")
}

model Inpatient {
  id              String           @id @default(cuid())
  clinicId        String
  petId           String
  cageId          String
  doctorId        String
  medicalRecordId String?
  status          InpatientStatus  @default(ADMITTED)
  admittedAt      DateTime         @default(now())
  dischargedAt    DateTime?
  diagnosis       String?
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  clinic      Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet         Pet                 @relation(fields: [petId], references: [id], onDelete: Cascade)
  cage        Cage                @relation(fields: [cageId], references: [id], onDelete: Cascade)
  doctor      User                @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  observations InpatientObservation[]

  @@index([clinicId])
  @@index([petId])
  @@index([cageId])
  @@index([status])
  @@map("inpatients")
}

model InpatientObservation {
  id           String   @id @default(cuid())
  inpatientId  String
  temperature  Float?
  weight       Float?
  generalCondition String?
  appetite     String?
  medication   String?
  notes        String?
  observedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  inpatient Inpatient @relation(fields: [inpatientId], references: [id], onDelete: Cascade)

  @@index([inpatientId])
  @@map("inpatient_observations")
}

// ========================
// GROOMING
// ========================

model Grooming {
  id          String         @id @default(cuid())
  clinicId    String
  petId       String
  customerId  String?
  serviceName String
  price       Float
  status      GroomingStatus @default(BOOKED)
  scheduledAt DateTime
  completedAt DateTime?
  photoBefore String?
  photoAfter  String?
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  pet    Pet    @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([petId])
  @@index([status])
  @@map("groomings")
}

// ========================
// INVENTORY
// ========================

model Product {
  id          String   @id @default(cuid())
  clinicId    String
  name        String
  category    String?
  description String?
  price       Float
  cost        Float?
  stock       Int      @default(0)
  minStock    Int      @default(0)
  unit        String?
  batchNumber String?
  expiryDate  DateTime?
  supplierId  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  clinic      Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  supplier    Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements StockMovement[]
  inventoryBatches InventoryBatch[]
  inventoryMovements InventoryMovement[]
  prescriptions Prescription[]
  invoiceItems InvoiceItem[]

  @@index([clinicId])
  @@index([name])
  @@index([category])
  @@index([expiryDate])
  @@map("products")
}

model Supplier {
  id        String   @id @default(cuid())
  clinicId  String
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  clinic   Clinic    @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([clinicId])
  @@map("suppliers")
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  type      String   // IN / OUT
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("stock_movements")
}

// ========================
// INVENTORY BATCH TRACKING
// ========================

model InventoryBatch {
  id        String   @id @default(cuid())
  productId String
  batchNumber String?
  expiryDate DateTime?
  quantity  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([batchNumber])
  @@index([expiryDate])
  @@map("inventory_batches")
}

model InventoryMovement {
  id        String       @id @default(cuid())
  productId String
  type      MovementType
  quantity  Int
  reference String?
  notes     String?
  createdAt DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_movements")
}

// ========================
// POS & INVOICE
// ========================

model Invoice {
  id             String        @id @default(cuid())
  clinicId       String
  customerId     String?
  userId         String
  invoiceNumber  String        @unique
  subtotal       Float
  discountTotal  Float         @default(0)
  total          Float
  status         InvoiceStatus @default(UNPAID)
  paymentMethod  PaymentMethod?
  notes          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  clinic  Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  customer Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    InvoiceItem[]

  @@index([clinicId])
  @@index([customerId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model InvoiceItem {
  id        String  @id @default(cuid())
  invoiceId String
  productId String?
  name      String
  quantity  Int
  price     Float
  discount  Float   @default(0)
  subtotal  Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_items")
}

// ========================
// PRESCRIPTION
// ========================

model Prescription {
  id              String   @id @default(cuid())
  medicalRecordId String
  productId       String
  dosage          String?
  frequency       String?
  duration        String?
  notes           String?
  createdAt       DateTime @default(now())

  medicalRecord MedicalRecord @relation(fields: [medicalRecordId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([medicalRecordId])
  @@map("prescriptions")
}

// ========================
// ACCOUNTING
// ========================

model AccountingTransaction {
  id          String   @id @default(cuid())
  clinicId    String
  type        String   // INCOME / EXPENSE
  category    String?
  amount      Float
  description String?
  date        DateTime @default(now())
  invoiceId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic  Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([type])
  @@index([date])
  @@map("accounting_transactions")
}

// ========================
// ACCOUNTING LEDGER (Double-Entry)
// ========================

model LedgerAccount {
  id        String   @id @default(cuid())
  clinicId  String
  code      String
  name      String
  type      String   // ASSET / LIABILITY / EQUITY / REVENUE / EXPENSE
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic            @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  journalLines JournalEntryLine[]

  @@unique([clinicId, code])
  @@index([clinicId])
  @@index([type])
  @@map("ledger_accounts")
}

model JournalEntry {
  id          String   @id @default(cuid())
  clinicId    String
  entryNumber String   @unique
  description String?
  date        DateTime @default(now())
  reference   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clinic Clinic              @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  lines  JournalEntryLine[]

  @@index([clinicId])
  @@index([date])
  @@map("journal_entries")
}

model JournalEntryLine {
  id              String  @id @default(cuid())
  journalEntryId  String
  accountId       String
  debit           Float   @default(0)
  credit          Float   @default(0)
  description     String?

  journalEntry JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      LedgerAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("journal_entry_lines")
}

// ========================
// NOTIFICATION
// ========================

model Notification {
  id        String   @id @default(cuid())
  clinicId  String
  userId    String?
  type      String   // WA / EMAIL
  channel   String   // WHATSAPP / EMAIL
  recipient String
  subject   String?
  message   String
  status    String   // PENDING / SENT / FAILED
  sentAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clinicId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

// ========================
// NOTIFICATION QUEUE
// ========================

model NotificationQueue {
  id          String      @id @default(cuid())
  clinicId    String
  userId      String?
  channel     String      // WHATSAPP / EMAIL
  recipient   String
  template    String?
  payload     Json?
  status      QueueStatus @default(PENDING)
  retryCount  Int         @default(0)
  maxRetries  Int         @default(3)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  clinic Clinic  @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  logs   NotificationLog[]

  @@index([clinicId])
  @@index([status])
  @@index([scheduledAt])
  @@map("notification_queue")
}

model NotificationLog {
  id        String   @id @default(cuid())
  queueId   String
  response  String?
  status    String
  createdAt DateTime @default(now())

  queue NotificationQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)

  @@index([queueId])
  @@map("notification_logs")
}

// ========================
// AUDIT LOG
// ========================

model AuditLog {
  id         String      @id @default(cuid())
  clinicId   String?
  userId     String
  action     AuditAction
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  clinic Clinic? @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}